{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake -S . -B build",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake --build build",
            "group": "build",
            "dependsOn": "CMake: Configure",
            "problemMatcher": []
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "ctest --test-dir build --output-on-failure",
            "group": "test",
            "problemMatcher": []
        }
    ]
}
